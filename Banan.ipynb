   "source": [
    "import numpy as np"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6f22ca2e",
   "metadata": {},
   "source": [
    "Definicja macierzy A"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "b40e6dc0",
   "metadata": {},
   "outputs": [],
   "source": [
    "A = np.array([\n",
    "    [1,2],\n",
    "    [3,4]\n",
    "])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d63e6e9e",
   "metadata": {},
   "source": [
    "Definicja macierzy B"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "d123e2de",
   "metadata": {},
   "outputs": [],
   "source": [
    "B = np.array([\n",
    "    [4,5],\n",
    "    [6,7]\n",
    "])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6604b2aa",
   "metadata": {},
   "source": [
    "Mnożenie macierzy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "796da20b",
   "metadata": {},
   "outputs": [],
   "source": [
    "C = np.dot(A, B)"
   ]
  },
